table Sales
	lineageTag: 97143e5b-7736-4fcb-8042-26b92b1f5684

	/// Number of distinct customers with at least one sale in the selected period
	measure '# Customers with Sales' = DISTINCTCOUNT('Sales'[Customer Key])
		formatString: #,##0
		displayFolder: 0. Measures\3. Lines
		lineageTag: 4ec872f0-a42d-4aa9-bf6b-1ca7c4916336

	/// Total quantity of items sold
	measure 'Sales Quantity' = sum('Sales'[Quantity])
		formatString: #,##0
		displayFolder: 0. Measures\2. Quantity
		lineageTag: c2ff8d96-2f03-4005-84df-91458625b73b

	/// Total sales amount calculated as the sum of quantity multiplied by net price
	measure 'Sales Amount' = SUMX('Sales', 'Sales'[Quantity] * 'Sales'[Net Price])
		formatString: $ #,##0
		displayFolder: 0. Measures\1. Value
		lineageTag: a8e95485-02a2-4525-b02a-b2418fbdbe4c

	/// Sales Amount for the same period last year using SAMEPERIODLASTYEAR
	measure 'Sales Amount LY' = IF ([Sales Amount] > 0, CALCULATE([Sales Amount], SAMEPERIODLASTYEAR('Calendar'[Date])))
		formatString: "€"#,0.###############;("€"#,0.###############);"€"#,0.###############
		displayFolder: 0. Measures\1. Value
		lineageTag: 3fa889ae-64b9-4a6e-b0e6-c81c90fd32bf

	/// Average daily sales amount for the selected period
	measure 'Sales Amount Daily Average' = AVERAGEX(VALUES('Calendar'[Date]), [Sales Amount])
		formatString: $ #,##0
		displayFolder: 0. Measures\1. Value
		lineageTag: 65842ce7-7176-4106-868e-2e83aaa62b4c

	/// Gross margin calculated as the sum of quantity multiplied by (net price minus unit cost)
	measure Margin =
			SUMX (
			    Sales,
			    Sales[Quantity]
			        * ( Sales[Net Price] - Sales[Unit Cost] )
			)
		formatString: $ #,##0
		displayFolder: 0. Measures\1. Value
		lineageTag: d22a262b-b776-4ccd-b9bd-7ef9c90eba51

	/// Total number of sales transaction lines
	measure '# Sales' = COUNTROWS('Sales')
		formatString: #,##02
		displayFolder: 0. Measures\3. Lines
		lineageTag: 67791bd1-5f33-4a29-a9ac-be0ad2453fcf

	/// Rolling 12-month average of daily sales amount ending on the last date with sales
	measure 'Sales Amount 12 Month Average' =
			
			VAR v_selDate =
			    MAX ( 'Calendar'[Date] )
			VAR v_period =
			    DATESINPERIOD ( 'Calendar'[Date], v_selDate, -12, MONTH )
			VAR v_result =
			    CALCULATE ( AVERAGEX ( VALUES ( 'Calendar'[Date] ), [Sales Amount] ), v_period )
			VAR v_firstDate =
			    MINX ( v_period, 'Calendar'[Date] )
			VAR v_lastDateSales =
			    MAX ( Sales[Order Date] )
			RETURN
			    IF ( v_firstDate <= v_lastDateSales, v_result )
		formatString: $ #,##0
		displayFolder: 0. Measures\1. Value
		lineageTag: 7fd60f7e-287e-46c3-a745-24c4507bc77b

	/// Rolling 6-month average of daily sales amount ending on the last date with sales
	measure 'Sales Amount 6 Month Average' =
			VAR v_selDate =
			    MAX ( 'Calendar'[Date] )
			VAR v_period =
			    DATESINPERIOD ( 'Calendar'[Date], v_selDate, -6, MONTH )
			VAR v_result =
			    CALCULATE ( AVERAGEX ( VALUES ( 'Calendar'[Date] ), [Sales Amount] ), v_period )
			VAR v_firstDate =
			    MINX ( v_period, 'Calendar'[Date] )
			VAR v_lastDateSales =
			    MAX ( Sales[Order Date] )
			RETURN
			    IF ( v_firstDate <= v_lastDateSales, v_result )
		formatString: $ #,##0
		displayFolder: 0. Measures\1. Value
		lineageTag: 9a48bea0-e5fb-40fa-9e81-f61288e31a02

	/// Total cost calculated as the sum of quantity multiplied by unit cost
	measure Cost = SUMX ( Sales, Sales[Quantity] * Sales[Unit Cost] )
		formatString: $ #,##0
		displayFolder: 0. Measures\1. Value
		lineageTag: 3e5cb67e-a411-476f-ad34-7ec10dfd084d

	/// Unique sales order identifier — a single order can have multiple lines
	column 'Order Number'
		dataType: int64
		formatString: 0
		displayFolder: 2. Degenerate Dimensions
		lineageTag: e2e629f1-f1fb-4444-a627-b121d77fdc06
		summarizeBy: none
		sourceColumn: Order Number

		annotation SummarizationSetBy = User

	/// Line number within a sales order
	column 'Line Number'
		dataType: int64
		formatString: 0
		displayFolder: 2. Degenerate Dimensions
		lineageTag: d4046972-90a5-46b2-badb-709e834b99af
		summarizeBy: none
		sourceColumn: Line Number

		annotation SummarizationSetBy = User

	/// Date the order was placed — used as the primary date relationship to Calendar
	column 'Order Date'
		dataType: dateTime
		formatString: Long Date
		displayFolder: 3. Keys\Dates
		lineageTag: d2d074d6-be1f-4dfd-b826-cd99fe83bc3a
		summarizeBy: none
		sourceColumn: Order Date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	/// Date the order was delivered
	column 'Delivery Date'
		dataType: dateTime
		formatString: Long Date
		displayFolder: 3. Keys\Dates
		lineageTag: 1056fc0f-d1e5-4872-a39b-25603dba5cf5
		summarizeBy: none
		sourceColumn: Delivery Date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column 'Customer Key'
