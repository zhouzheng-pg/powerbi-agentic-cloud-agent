	/// Unit cost of the product at time of sale — used in margin and cost calculations
	column 'Unit Cost'
		dataType: decimal
		isHidden
		isAvailableInMdx: false
		displayFolder: 1. Facts
		lineageTag: 03a43676-2ce4-4678-a4a7-0ee8f4e00b17
